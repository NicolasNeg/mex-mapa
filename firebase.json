{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "serviceAccountKey.json",
      "backups",
      "backups/**",
      "preview",
      "preview/**",
      "scripts",
      "scripts/**",
      "docs",
      "docs/**",
      ".superpowers",
      ".superpowers/**",
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      "MIGRAR_A_FIREBASE.gs",
      "README.md",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      "functions",
      "functions/**",
      ".env",
      ".env.*",
      "base64",
      "**/*.bak",
      "**/.git/**",
      "**/.github/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/app",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/app/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/login",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/mapa",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/programador",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/programador/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/home",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/gestion",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/mensajes",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/profile",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/cola-preparacion",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/editmap",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/editmap/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/incidencias",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/cuadre",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/cuadre/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/mex-api.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/js/core/firebase-config.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/js/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/domain/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/css/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "redirects": [
      { "source": "/", "destination": "/app", "type": 302 }
    ],
    "rewrites": [
      { "source": "/login",       "destination": "/login.html" },
      { "source": "/mapa",        "destination": "/mapa.html" },
      { "source": "/programador", "destination": "/programador.html" },
      { "source": "/programador/**", "destination": "/programador.html" },
      { "source": "/home",        "destination": "/home.html" },
      { "source": "/gestion",     "destination": "/gestion.html" },
      { "source": "/mensajes",    "destination": "/mensajes.html" },
      { "source": "/profile",     "destination": "/profile.html" },
      { "source": "/cola-preparacion", "destination": "/cola-preparacion.html" },
      { "source": "/editmap",     "destination": "/editmap.html" },
      { "source": "/editmap/**",  "destination": "/editmap.html" },
      { "source": "/incidencias",   "destination": "/incidencias.html" },
      { "source": "/cuadre",        "destination": "/cuadre.html" },
      { "source": "/cuadre/**",     "destination": "/cuadre.html" },
      { "source": "/app",           "destination": "/app.html" },
      { "source": "/app/**",        "destination": "/app.html" }
    ]
  }
}
