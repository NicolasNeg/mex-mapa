{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      "MIGRAR_A_FIREBASE.gs",
      "README.md",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      "functions",
      "functions/**",
      ".env",
      ".env.*",
      "base64",
      "**/*.bak",
      "**/.git/**",
      "**/.github/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/mex-api.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/config.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/js/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/css/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "redirects": [
      { "source": "/", "destination": "/app", "type": 302 }
    ],
    "rewrites": [
      { "source": "/login",       "destination": "/login.html" },
      { "source": "/mapa",        "destination": "/mapa.html" },
      { "source": "/programador", "destination": "/programador.html" },
      { "source": "/home",        "destination": "/home.html" },
      { "source": "/gestion",     "destination": "/gestion.html" },
      { "source": "/mensajes",    "destination": "/mensajes.html" },
      { "source": "/profile",     "destination": "/profile.html" },
      { "source": "/cola-preparacion", "destination": "/cola-preparacion.html" },
      { "source": "/editmap",     "destination": "/editmap.html" },
      { "source": "/editmap/**",  "destination": "/editmap.html" },
      { "source": "/solicitud",     "destination": "/solicitud.html" },
      { "source": "/incidencias",   "destination": "/incidencias.html" },
      { "source": "/cuadre",        "destination": "/cuadre.html" },
      { "source": "/cuadre/**",     "destination": "/cuadre.html" },
      { "source": "/app",           "destination": "/app.html" },
      { "source": "/app/**",        "destination": "/app.html" }
    ]
  }
}
