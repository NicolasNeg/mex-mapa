rules_version = '2';
// ============================================================
// REGLAS DE SEGURIDAD FIRESTORE — MEX MAPA
// Jerarquía de acceso basada en perfiles guardados en /usuarios.
// Compatibilidad legacy: si un perfil no tiene "rol", se infiere
// desde isAdmin / isGlobal.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PERFIL Y ROLES ─────────────────────────────────────
    function estaAutenticado() {
      return request.auth != null;
    }

    function tienePerfilUid() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function tienePerfilEmail() {
      return estaAutenticado()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email));
    }

    function tienePerfilActual() {
      return tienePerfilUid() || tienePerfilEmail();
    }

    function esEmailBootstrapProgramador(email) {
      return email != null
        && (
          email == "angelarmentta@icloud.com"
        );
    }

    function esProgramadorBootstrap() {
      return estaAutenticado()
        && esEmailBootstrapProgramador(request.auth.token.email);
    }

    function perfilActual() {
      return tienePerfilEmail()
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data
        : get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function empresaConfig() {
      return exists(/databases/$(database)/documents/configuracion/empresa)
        ? get(/databases/$(database)/documents/configuracion/empresa).data
        : {};
    }

    function seguridadConfig() {
      return empresaConfig().security != null && empresaConfig().security is map
        ? empresaConfig().security
        : {};
    }

    function rolesConfig() {
      return seguridadConfig().roles != null && seguridadConfig().roles is map
        ? seguridadConfig().roles
        : {};
    }

    function rolConfig(role) {
      return rolesConfig().keys().hasAny([role]) ? rolesConfig()[role] : null;
    }

    function rolValido(role) {
      return role == "AUXILIAR"
        || role == "VENTAS"
        || role == "SUPERVISOR"
        || role == "JEFE_PATIO"
        || role == "GERENTE_PLAZA"
        || role == "JEFE_REGIONAL"
        || role == "CORPORATIVO_USER"
        || role == "PROGRAMADOR"
        || role == "JEFE_OPERACION"
        || rolesConfig().keys().hasAny([role]);
    }

    function permisoOverride(perfil, permiso) {
      return perfil.permissionOverrides != null
        && perfil.permissionOverrides is map
        && perfil.permissionOverrides.keys().hasAny([permiso])
        ? perfil.permissionOverrides[permiso]
        : null;
    }

    function rolTienePermiso(role, permiso) {
      return role == "PROGRAMADOR" || role == "JEFE_OPERACION" || role == "CORPORATIVO_USER"
        ? true
        : permiso == "view_admin_cuadre"
          ? (
            role == "VENTAS"
            || role == "SUPERVISOR"
            || role == "JEFE_PATIO"
            || role == "GERENTE_PLAZA"
            || role == "JEFE_REGIONAL"
            || (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "edit_admin_cuadre"
          ? (
            role == "SUPERVISOR"
            || role == "JEFE_PATIO"
            || role == "GERENTE_PLAZA"
            || role == "JEFE_REGIONAL"
            || (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "manage_users"
          ? (
            (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "process_access_requests"
          ? (
            (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "manage_global_fleet"
          ? (
            role == "GERENTE_PLAZA"
            || role == "JEFE_REGIONAL"
            || (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "manage_system_settings"
          ? (
            (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "use_programmer_console"
          ? (
            (rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true)
          )
        : permiso == "platform_full_access"
          ? (
            rolConfig(role) != null
            && (
              (rolConfig(role).fullAccess != null && rolConfig(role).fullAccess == true)
              || (rolConfig(role).permissions is map
                && rolConfig(role).permissions.keys().hasAny([permiso])
                && rolConfig(role).permissions[permiso] == true)
            )
          )
        : false;
    }

    function tienePermiso(perfil, permiso) {
      return esProgramadorBootstrap()
        || permisoOverride(perfil, permiso) == true
        || (
          permisoOverride(perfil, permiso) == null
          && rolTienePermiso(rolDePerfil(perfil), permiso)
        );
    }

    function rolDePerfil(data) {
      return esEmailBootstrapProgramador(data.email) ? "PROGRAMADOR"
        : data.rol is string && rolValido(data.rol) ? data.rol
        : data.isGlobal == true ? "CORPORATIVO_USER"
        : data.isAdmin == true ? "VENTAS"
        : "AUXILIAR";
    }

    function rolActual() {
      return esProgramadorBootstrap() ? "PROGRAMADOR"
        : !tienePerfilActual() ? "SIN_ACCESO"
        : rolDePerfil(perfilActual());
    }

    function esAccesoTotal() {
      return tienePerfilActual() && tienePermiso(perfilActual(), "platform_full_access");
    }

    function esJefeOperacionOProgramador() {
      return rolActual() == "PROGRAMADOR" || rolActual() == "JEFE_OPERACION";
    }

    function esAdminOperativo() {
      return tienePerfilActual()
        && (
          tienePermiso(perfilActual(), "view_admin_cuadre")
          || tienePermiso(perfilActual(), "edit_admin_cuadre")
        );
    }

    function puedeGestionarUsuarios() {
      return tienePerfilActual() && tienePermiso(perfilActual(), "manage_users");
    }

    function puedeGestionarSolicitudes() {
      return tienePerfilActual() && tienePermiso(perfilActual(), "process_access_requests");
    }

    function puedeEditarCuadreAdmins() {
      return tienePerfilActual() && tienePermiso(perfilActual(), "edit_admin_cuadre");
    }

    function puedeGestionarFlotaMaestra() {
      return tienePerfilActual()
        && (
          tienePermiso(perfilActual(), "manage_global_fleet")
          || esAccesoTotal()
        );
    }

    function plazaActual() {
      return !tienePerfilActual() ? ""
        : perfilActual().plazaAsignada != null ? perfilActual().plazaAsignada
        : perfilActual().plaza != null ? perfilActual().plaza
        : "";
    }

    function mismaPlaza(plaza) {
      return esAccesoTotal()
        || (
          rolRequierePlaza(rolActual())
          && plazaActual() != ""
          && plaza != null
          && plaza != ""
          && plaza == plazaActual()
        );
    }

    function rolRequierePlaza(role) {
      return role == "VENTAS"
        || role == "SUPERVISOR"
        || role == "JEFE_PATIO"
        || role == "GERENTE_PLAZA"
        || role == "JEFE_REGIONAL"
        || (
          rolConfig(role) != null
          && rolConfig(role).needsPlaza != null
          && rolConfig(role).needsPlaza == true
        );
    }

    function perfilUsuarioValido(data) {
      return data.nombre is string
        && data.email is string
        && data.telefono is string
        && data.rol is string
        && data.plazaAsignada is string
        && data.isAdmin is bool
        && data.isGlobal is bool
        && (data.status == null || data.status is string)
        && rolValido(data.rol)
        && rolDePerfil(data) == data.rol
        && (!rolRequierePlaza(data.rol) || data.plazaAsignada.size() > 0);
    }

    function actorPuedeGestionarRol(role) {
      return esJefeOperacionOProgramador()
        || (
          rolActual() == "CORPORATIVO_USER"
          && role != "CORPORATIVO_USER"
          && role != "PROGRAMADOR"
          && role != "JEFE_OPERACION"
          && (
            rolConfig(role) == null
            || (
              (rolConfig(role).fullAccess == null || rolConfig(role).fullAccess != true)
              && (
                !(rolConfig(role).permissions is map)
                || !rolConfig(role).permissions.keys().hasAny(["use_programmer_console", "manage_system_settings"])
              )
            )
          )
        );
    }

    function puedeCrearUsuario(data) {
      return puedeGestionarUsuarios()
        && perfilUsuarioValido(data)
        && actorPuedeGestionarRol(data.rol);
    }

    function puedeActualizarUsuario(actual, nuevo) {
      return puedeCrearUsuario(nuevo)
        && actorPuedeGestionarRol(rolDePerfil(actual));
    }

    function puedeEliminarUsuario(actual) {
      return puedeGestionarUsuarios()
        && actorPuedeGestionarRol(rolDePerfil(actual));
    }

    function esDocumentoUsuarioPropio(docId) {
      return estaAutenticado()
        && (
          docId == request.auth.token.email
          || docId == request.auth.uid
        );
    }

    function actualizacionSelfServiceUsuarioValida(docId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return esDocumentoUsuarioPropio(docId)
        && changed.hasOnly([
          "_reloadRequired",
          "isOnline",
          "lastSeenAt",
          "lastActiveAt",
          "avatarUrl",
          "avatarPath",
          "photoURL",
          "fotoURL",
          "profilePhotoUrl"
        ])
        && (!changed.hasAny(["_reloadRequired"]) || request.resource.data._reloadRequired == false)
        && (!changed.hasAny(["isOnline"]) || request.resource.data.isOnline is bool)
        && (!changed.hasAny(["lastSeenAt"]) || request.resource.data.lastSeenAt is int)
        && (!changed.hasAny(["lastActiveAt"]) || request.resource.data.lastActiveAt is int)
        && (!changed.hasAny(["avatarUrl"]) || request.resource.data.avatarUrl is string)
        && (!changed.hasAny(["avatarPath"]) || request.resource.data.avatarPath is string)
        && (!changed.hasAny(["photoURL"]) || request.resource.data.photoURL is string)
        && (!changed.hasAny(["fotoURL"]) || request.resource.data.fotoURL is string)
        && (!changed.hasAny(["profilePhotoUrl"]) || request.resource.data.profilePhotoUrl is string);
    }

    function deviceDocValido(deviceId) {
      return request.resource.data.deviceId == deviceId
        && request.resource.data.deviceId is string
        && (request.resource.data.token == null || request.resource.data.token is string)
        && (request.resource.data.permission == null || request.resource.data.permission is string)
        && (request.resource.data.platform == null || request.resource.data.platform is string)
        && (request.resource.data.browser == null || request.resource.data.browser is string)
        && (request.resource.data.userAgent == null || request.resource.data.userAgent is string)
        && (request.resource.data.plaza == null || request.resource.data.plaza is string)
        && (request.resource.data.role == null || request.resource.data.role is string)
        && (request.resource.data.appVersion == null || request.resource.data.appVersion is string)
        && (request.resource.data.swVersion == null || request.resource.data.swVersion is string)
        && (request.resource.data.createdAt == null || request.resource.data.createdAt is int)
        && (request.resource.data.updatedAt == null || request.resource.data.updatedAt is int)
        && (request.resource.data.lastSeenAt == null || request.resource.data.lastSeenAt is int)
        && (request.resource.data.isFocused == null || request.resource.data.isFocused is bool)
        && (request.resource.data.activeRoute == null || request.resource.data.activeRoute is string)
        && (request.resource.data.invalidToken == null || request.resource.data.invalidToken is bool)
        && (request.resource.data.pushEnabled == null || request.resource.data.pushEnabled is bool)
        && (request.resource.data.suppressWhileFocused == null || request.resource.data.suppressWhileFocused is bool)
        && (request.resource.data.notificationPrefs == null || request.resource.data.notificationPrefs is map);
    }

    function inboxAckValido() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(["read", "readAt", "status"])
        && request.resource.data.read is bool
        && request.resource.data.readAt is int
        && request.resource.data.status is string;
    }

    function programmerErrorCreateValido() {
      return request.resource.data.keys().hasAll(["timestamp", "fecha", "kind", "scope", "message"])
        && request.resource.data.keys().hasOnly([
          "timestamp", "fecha", "kind", "scope", "message", "stack", "code", "route",
          "plaza", "role", "userDocId", "userEmail", "userName", "build",
          "source", "userAgent"
        ])
        && request.resource.data.timestamp is int
        && request.resource.data.fecha is string
        && request.resource.data.kind is string
        && request.resource.data.scope is string
        && request.resource.data.message is string
        && (request.resource.data.stack == null || request.resource.data.stack is string)
        && (request.resource.data.code == null || request.resource.data.code is string)
        && (request.resource.data.route == null || request.resource.data.route is string)
        && (request.resource.data.plaza == null || request.resource.data.plaza is string)
        && (request.resource.data.role == null || request.resource.data.role is string)
        && (request.resource.data.userDocId == null || request.resource.data.userDocId is string)
        && (request.resource.data.userEmail == null || request.resource.data.userEmail is string)
        && (request.resource.data.userName == null || request.resource.data.userName is string)
        && (request.resource.data.build == null || request.resource.data.build is string)
        && (request.resource.data.source == null || request.resource.data.source is string)
        && (request.resource.data.userAgent == null || request.resource.data.userAgent is string);
    }

    function solicitudCreateValida(docId) {
      return request.resource.data.keys().hasAll([
          "nombre", "email", "puesto", "telefono", "password",
          "fecha", "estado"
        ])
        && request.resource.data.keys().hasOnly([
          "nombre", "email", "puesto", "telefono", "password",
          "rolSolicitado", "plazaSolicitada", "fecha", "estado"
        ])
        && request.resource.data.nombre is string
        && request.resource.data.email is string
        && request.resource.data.puesto is string
        && request.resource.data.telefono is string
        && request.resource.data.password is string
        && request.resource.data.fecha is string
        && docId == request.resource.data.email
        && (
          request.resource.data.rolSolicitado == null
          || rolValido(request.resource.data.rolSolicitado)
        )
        && (
          request.resource.data.plazaSolicitada == null
          || request.resource.data.plazaSolicitada is string
        )
        && request.resource.data.estado == "PENDIENTE"
        && request.resource.data.nombre.size() >= 3
        && request.resource.data.email.size() >= 5
        && request.resource.data.password.size() >= 6;
    }

    function solicitudUpdateValida() {
      return puedeGestionarSolicitudes()
        && request.resource.data.nombre == resource.data.nombre
        && request.resource.data.email == resource.data.email
        && request.resource.data.puesto == resource.data.puesto
        && request.resource.data.telefono == resource.data.telefono
        && request.resource.data.fecha == resource.data.fecha
        && request.resource.data.rolSolicitado == resource.data.rolSolicitado
        && request.resource.data.plazaSolicitada == resource.data.plazaSolicitada
        && request.resource.data.password == ""
        && (
          request.resource.data.estado == "APROBADA"
          || request.resource.data.estado == "RECHAZADA"
        )
        && (
          request.resource.data.motivo_rechazo == null
          || request.resource.data.motivo_rechazo is string
        );
    }

    function eventoGestionValido() {
      return request.resource.data.keys().hasAll([
          "fecha", "timestamp", "tipo", "accion", "autor"
        ])
        && request.resource.data.keys().hasOnly([
          "fecha", "timestamp", "tipo", "accion", "autor",
          "entidad", "referencia", "detalles", "objetivo",
          "rolObjetivo", "plazaObjetivo", "resultado"
        ])
        && request.resource.data.fecha is string
        && request.resource.data.timestamp is int
        && request.resource.data.tipo is string
        && request.resource.data.accion is string
        && request.resource.data.autor is string
        && (request.resource.data.entidad == null || request.resource.data.entidad is string)
        && (request.resource.data.referencia == null || request.resource.data.referencia is string)
        && (request.resource.data.detalles == null || request.resource.data.detalles is string)
        && (request.resource.data.objetivo == null || request.resource.data.objetivo is string)
        && (request.resource.data.rolObjetivo == null || request.resource.data.rolObjetivo is string)
        && (request.resource.data.plazaObjetivo == null || request.resource.data.plazaObjetivo is string)
        && (request.resource.data.resultado == null || request.resource.data.resultado is string);
    }

    function alertaLecturaValida() {
      return tienePerfilActual()
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.fecha == resource.data.fecha
        && request.resource.data.autor == resource.data.autor
        && request.resource.data.tipo == resource.data.tipo
        && request.resource.data.titulo == resource.data.titulo
        && request.resource.data.mensaje == resource.data.mensaje
        && request.resource.data.imagen == resource.data.imagen
        && request.resource.data.leidoPor is string;
    }

    function plazaIndexNueva() {
      return request.resource.data.sucursal != null
        ? request.resource.data.sucursal
        : request.resource.data.plaza;
    }

    function plazaIndexActual() {
      return resource.data.sucursal != null
        ? resource.data.sucursal
        : resource.data.plaza;
    }

    function plazaCuadreAdminNueva() {
      return request.resource.data.plaza != null
        ? request.resource.data.plaza
        : request.resource.data.ubicacion;
    }

    function plazaCuadreAdminActual() {
      return resource.data.plaza != null
        ? resource.data.plaza
        : resource.data.ubicacion;
    }

    // ─── DATOS OPERATIVOS DEL MAPA ───────────────────────────
    // mapa_config/{plazaId}            → documento raíz por plaza (o doc legacy "cel_*")
    // mapa_config/{plazaId}/estructura → subcolección con las celdas del mapa
    match /mapa_config/{plazaId} {
      allow read: if tienePerfilActual();
      allow write: if esAccesoTotal();
      match /estructura/{cel} {
        allow read: if tienePerfilActual();
        allow write: if esAccesoTotal();
      }
    }

    // F7 Extras de unidad (tags, recordatorios, notas rápidas)
    match /unit_extras/{docId} {
      allow read: if tienePerfilActual();
      allow write: if tienePerfilActual();
    }

    // F6.2 Plantillas de mapa (acceso total para lectura/escritura)
    match /mapa_plantillas/{plantillaId} {
      allow read: if tienePerfilActual();
      allow write: if esAccesoTotal();
      match /estructura/{cel} {
        allow read: if tienePerfilActual();
        allow write: if esAccesoTotal();
      }
    }

    match /index_unidades/{doc} {
      allow read: if tienePerfilActual();
      allow create: if puedeGestionarFlotaMaestra() && mismaPlaza(plazaIndexNueva());
      allow update: if puedeGestionarFlotaMaestra()
        && mismaPlaza(plazaIndexActual())
        && mismaPlaza(plazaIndexNueva());
      allow delete: if puedeGestionarFlotaMaestra() && mismaPlaza(plazaIndexActual());
    }

    // ─── CUADRE Y EXTERNOS — ESCALABILIDAD POR PLAZA ────────
    // Nueva arquitectura: cuadre/{plaza}/unidades/{mvaId}
    // Legacy: cuadre/{mvaId}  (docs raíz sin subcollección)
    match /cuadre/{doc} {
      allow read, write: if tienePerfilActual();
      match /unidades/{unidad} {
        allow read: if tienePerfilActual();
        allow write: if mismaPlaza(doc) || esAccesoTotal();
      }
    }

    match /externos/{doc} {
      allow read, write: if tienePerfilActual();
      match /unidades/{unidad} {
        allow read: if tienePerfilActual();
        allow write: if mismaPlaza(doc) || esAccesoTotal();
      }
    }

    // collectionGroup — lecturas cross-plaza (Fase 2/3)
    match /{path=**}/unidades/{doc} {
      allow read: if tienePerfilActual();
    }
    match /{path=**}/registros/{doc} {
      allow read: if esAdminOperativo();
    }

    match /historial_patio/{doc} {
      allow read, write: if tienePerfilActual();
    }

    // Cuadre Admins — doc raíz (legacy) + subcollection por plaza (Fase 3)
    match /cuadre_admins/{doc} {
      allow read: if esAdminOperativo();
      allow create: if puedeEditarCuadreAdmins() && mismaPlaza(plazaCuadreAdminNueva());
      allow update: if puedeEditarCuadreAdmins()
        && mismaPlaza(plazaCuadreAdminActual())
        && mismaPlaza(plazaCuadreAdminNueva());
      allow delete: if puedeEditarCuadreAdmins() && mismaPlaza(plazaCuadreAdminActual());
      match /registros/{registro} {
        allow read: if esAdminOperativo();
        allow write: if puedeEditarCuadreAdmins() && mismaPlaza(doc);
      }
    }

    // Historial cuadres — doc raíz (legacy) + subcollection por plaza (Fase 3)
    match /historial_cuadres/{doc} {
      allow read, write: if tienePerfilActual();
      match /registros/{registro} {
        allow read: if tienePerfilActual();
        allow write: if esAdminOperativo() && mismaPlaza(doc);
      }
    }

    match /auditoria/{doc} {
      allow read, write: if tienePerfilActual();
    }

    match /sipp/{doc} {
      allow read, write: if tienePerfilActual();
    }

    // ─── USUARIOS Y PERMISOS ─────────────────────────────────
    match /usuarios/{doc} {
      allow read: if tienePerfilActual();
      allow create: if puedeCrearUsuario(request.resource.data);
      allow update: if puedeActualizarUsuario(resource.data, request.resource.data)
        || actualizacionSelfServiceUsuarioValida(doc);
      allow delete: if puedeEliminarUsuario(resource.data);

      match /devices/{deviceId} {
        allow read: if esAccesoTotal() || esDocumentoUsuarioPropio(doc);
        allow create, update: if esAccesoTotal()
          || (esDocumentoUsuarioPropio(doc) && deviceDocValido(deviceId));
        allow delete: if esAccesoTotal() || esDocumentoUsuarioPropio(doc);
      }

      match /inbox/{notifId} {
        allow read: if esAccesoTotal() || esDocumentoUsuarioPropio(doc);
        allow create: if false;
        allow update: if esAccesoTotal() || (esDocumentoUsuarioPropio(doc) && inboxAckValido());
        allow delete: if esAccesoTotal();
      }
    }

    match /admins/{doc} {
      allow read: if tienePerfilActual();
      allow write: if esJefeOperacionOProgramador();
    }

    // ─── COMUNICACIÓN Y LOGS ─────────────────────────────────
    match /alertas/{doc} {
      allow read: if tienePerfilActual();
      allow create, delete: if esAccesoTotal();
      allow update: if esAccesoTotal() || alertaLecturaValida();
    }

    match /mensajes/{doc} {
      allow read, write: if tienePerfilActual();
    }

    match /logs/{doc} {
      allow read, write: if tienePerfilActual();
    }

    match /bitacora_gestion/{doc} {
      allow read: if esAccesoTotal();
      allow create: if esAdminOperativo() && eventoGestionValido();
      allow update, delete: if false;
    }

    match /notas_admin/{doc} {
      allow read, write: if tienePerfilActual();
    }

    match /settings/{doc} {
      allow read: if tienePerfilActual();
      allow write: if tienePerfilActual() && (tienePermiso(perfilActual(), "manage_system_settings") || tienePermiso(perfilActual(), "lock_map"));
    }

    match /ops_events/{doc} {
      allow read: if tienePerfilActual();
      allow write: if false;
    }

    match /programmer_jobs/{doc} {
      allow read: if tienePerfilActual() && tienePermiso(perfilActual(), "use_programmer_console");
      allow write: if false;
    }

    match /programmer_audit/{doc} {
      allow read: if tienePerfilActual() && tienePermiso(perfilActual(), "use_programmer_console");
      allow write: if false;
    }

    match /programmer_errors/{doc} {
      allow create: if tienePerfilActual() && programmerErrorCreateValido();
      allow read: if tienePerfilActual() && tienePermiso(perfilActual(), "use_programmer_console");
      allow update, delete: if false;
    }

    // ─── CONFIGURACIÓN GLOBAL ────────────────────────────────
    // configuracion/empresa, configuracion/listas → lectura pública (branding en login)
    // configuracion/{plaza} → catálogos por plaza (Fase 4: ubicaciones)
    match /configuracion/{document} {
      // "empresa" y "listas" se leen antes de autenticación (login branding)
      allow read: if document == "empresa" || document == "listas" || tienePerfilActual();
      allow write: if tienePerfilActual()
        && tienePermiso(perfilActual(), "manage_system_settings");
      match /{subcol=**} {
        allow read: if tienePerfilActual();
        allow write: if tienePerfilActual()
          && mismaPlaza(document)
          && tienePermiso(perfilActual(), "manage_system_settings");
      }
    }

    // ─── SOLICITUDES DE ACCESO ───────────────────────────────
    match /solicitudes_acceso/{doc} {
      allow create: if solicitudCreateValida(doc);
      allow read, delete: if puedeGestionarSolicitudes();
      allow update: if solicitudUpdateValida();
    }
  }
}
