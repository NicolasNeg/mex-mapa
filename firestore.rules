rules_version = '2';
// ============================================================
// REGLAS DE SEGURIDAD FIRESTORE — MEX MAPA
// Requiere sesión de Firebase Auth para casi todo.
// La única excepción es solicitudes_acceso (envío sin sesión).
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER ─────────────────────────────────────────────
    function estaAutenticado() {
      return request.auth != null;
    }

    // ─── DATOS OPERATIVOS DEL MAPA ───────────────────────────
    match /mapa_config/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /index_unidades/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /cuadre/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /externos/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /historial_patio/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /cuadre_admins/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /historial_cuadres/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /auditoria/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /sipp/{doc} {
      allow read, write: if estaAutenticado();
    }

    // ─── USUARIOS Y PERMISOS ─────────────────────────────────
    // Lectura necesaria para validar login; escritura solo autenticados
    match /usuarios/{doc} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado();
    }

    match /admins/{doc} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado();
    }

    // ─── COMUNICACIÓN Y LOGS ─────────────────────────────────
    match /alertas/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /mensajes/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /logs/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /notas_admin/{doc} {
      allow read, write: if estaAutenticado();
    }

    match /settings/{doc} {
      allow read, write: if estaAutenticado();
    }

    // ─── CONFIGURACIÓN GLOBAL ────────────────────────────────
    match /configuracion/{document=**} {
      allow read, write: if estaAutenticado();
    }

    // ─── SOLICITUDES DE ACCESO ───────────────────────────────
    // Abierto: el solicitante aún no tiene cuenta, no puede autenticarse.
    // Solo permite crear (create), no leer ni modificar registros ajenos.
    match /solicitudes_acceso/{doc} {
      allow create: if true;
      allow read, update, delete: if estaAutenticado();
    }

  }
}
