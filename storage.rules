rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function estaAutenticado() {
      return request.auth != null;
    }

    function tienePerfilUid() {
      return estaAutenticado()
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }

    function tienePerfilEmail() {
      return estaAutenticado()
        && request.auth.token.email != null
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.token.email));
    }

    function tienePerfilActual() {
      return tienePerfilUid() || tienePerfilEmail();
    }

    function esEmailBootstrapProgramador(email) {
      return email != null
        && email == "angelarmentta@icloud.com";
    }

    function perfilActual() {
      return tienePerfilEmail()
        ? firestore.get(/databases/(default)/documents/usuarios/$(request.auth.token.email)).data
        : firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data;
    }

    function empresaConfig() {
      return firestore.exists(/databases/(default)/documents/configuracion/empresa)
        ? firestore.get(/databases/(default)/documents/configuracion/empresa).data
        : {};
    }

    function seguridadConfig() {
      return empresaConfig().security != null && empresaConfig().security is map
        ? empresaConfig().security
        : {};
    }

    function rolConfig(role) {
      return seguridadConfig().roles != null
        && seguridadConfig().roles is map
        && seguridadConfig().roles.keys().hasAny([role])
        ? seguridadConfig().roles[role]
        : null;
    }

    function rolActual() {
      return estaAutenticado() && esEmailBootstrapProgramador(request.auth.token.email) ? "PROGRAMADOR"
        : !tienePerfilActual() ? "SIN_ACCESO"
        : perfilActual().rol == "PROGRAMADOR" ? "PROGRAMADOR"
        : perfilActual().rol == "JEFE_OPERACION" ? "JEFE_OPERACION"
        : perfilActual().rol == "CORPORATIVO_USER" ? "CORPORATIVO_USER"
        : perfilActual().rol == "JEFE_REGIONAL" ? "JEFE_REGIONAL"
        : perfilActual().rol == "JEFE_PATIO" ? "JEFE_PATIO"
        : perfilActual().rol == "SUPERVISOR" ? "SUPERVISOR"
        : perfilActual().rol == "GERENTE_PLAZA" ? "GERENTE_PLAZA"
        : perfilActual().rol == "VENTAS" ? "VENTAS"
        : perfilActual().rol != null
          && seguridadConfig().roles != null
          && seguridadConfig().roles is map
          && seguridadConfig().roles.keys().hasAny([perfilActual().rol]) ? perfilActual().rol
        : perfilActual().isGlobal == true ? "CORPORATIVO_USER"
        : perfilActual().isAdmin == true ? "VENTAS"
        : "AUXILIAR";
    }

    function permisoOverride(permiso) {
      return tienePerfilActual()
        && perfilActual().permissionOverrides != null
        && perfilActual().permissionOverrides is map
        && perfilActual().permissionOverrides.keys().hasAny([permiso])
        ? perfilActual().permissionOverrides[permiso]
        : null;
    }

    function rolTienePermiso(role, permiso) {
      return role == "PROGRAMADOR" || role == "JEFE_OPERACION" || role == "CORPORATIVO_USER"
        ? true
        : permiso == "edit_admin_cuadre"
          ? (
            role == "SUPERVISOR"
            || role == "JEFE_PATIO"
            || role == "GERENTE_PLAZA"
            || role == "JEFE_REGIONAL"
            || (
              rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true
            )
          )
        : permiso == "view_admin_cuadre"
          ? (
            role == "VENTAS"
            || role == "SUPERVISOR"
            || role == "JEFE_PATIO"
            || role == "GERENTE_PLAZA"
            || role == "JEFE_REGIONAL"
            || (
              rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true
            )
          )
        : permiso == "manage_users" || permiso == "view_admin_users"
          ? (
            (
              rolConfig(role) != null
              && rolConfig(role).permissions is map
              && rolConfig(role).permissions.keys().hasAny([permiso])
              && rolConfig(role).permissions[permiso] == true
            )
          )
        : permiso == "manage_system_settings" || permiso == "manage_settings"
          ? (
            rolConfig(role) != null
            && rolConfig(role).permissions is map
            && rolConfig(role).permissions.keys().hasAny([permiso])
            && rolConfig(role).permissions[permiso] == true
          )
        : false;
    }

    function tienePermiso(permiso) {
      return esEmailBootstrapProgramador(request.auth.token.email)
        || permisoOverride(permiso) == true
        || (permisoOverride(permiso) == null && rolTienePermiso(rolActual(), permiso));
    }

    function esAccesoTotal() {
      return rolActual() == "PROGRAMADOR"
        || rolActual() == "JEFE_OPERACION"
        || rolActual() == "CORPORATIVO_USER"
        || (
          rolConfig(rolActual()) != null
          && rolConfig(rolActual()).fullAccess != null
          && rolConfig(rolActual()).fullAccess == true
        );
    }

    function esAdminOperativo() {
      return tienePermiso("view_admin_cuadre") || tienePermiso("edit_admin_cuadre");
    }

    function puedeEditarCuadreAdmins() {
      return tienePermiso("edit_admin_cuadre");
    }

    function puedeGestionarCatalogos() {
      return esAccesoTotal()
        || tienePermiso("manage_system_settings")
        || tienePermiso("manage_settings");
    }

    function esDocumentoUsuarioPropio(docId) {
      return estaAutenticado()
        && (
          docId == request.auth.token.email
          || docId == request.auth.uid
        );
    }

    match /evidencias_cuadre_admins/{docId}/{fileName} {
      allow read: if esAdminOperativo();
      allow write: if puedeEditarCuadreAdmins()
        && (request.resource == null || request.resource.size < 35 * 1024 * 1024);
    }

    match /notas_admin_adjuntos/{docId}/{fileName} {
      allow read, write: if tienePerfilActual();
    }

    match /profile_avatars/{userDocId}/{fileName} {
      allow read: if tienePerfilActual();
      // request.resource == null en un DELETE (limpieza del avatar anterior).
      // Antes exigíamos size/contentType siempre → el delete daba 403 porque
      // esos campos no existen al borrar. Ahora: borrar si es dueño; subir si
      // además es imagen válida y de tamaño permitido.
      allow write: if esDocumentoUsuarioPropio(userDocId)
        && (
          request.resource == null
          || (
            request.resource.size < 12 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    // Selfies de check-in/out de turnos (checado facial).
    // Path: turnos_checadas/{auth.uid}/{inicio|cierre}_*.jpg
    match /turnos_checadas/{userDocId}/{fileName} {
      allow read: if tienePerfilActual();
      allow write: if esDocumentoUsuarioPropio(userDocId)
        && (
          request.resource == null
          || (
            request.resource.size < 8 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    match /licencias_choferes/{userDocId}/{fileName} {
      allow read: if tienePerfilActual();
      // Quien puede ver la vista de usuarios/choferes puede registrar licencias.
      allow write: if (tienePermiso("manage_users") || tienePermiso("view_admin_users"))
        && (
          request.resource == null
          || (
            request.resource.size < 12 * 1024 * 1024
            && (
              request.resource.contentType.matches('image/.*')
              || request.resource.contentType == 'application/pdf'
            )
          )
        );
    }

    match /empresa_config/{fileName} {
      allow read: if tienePerfilActual();
      allow write: if puedeGestionarCatalogos()
        && (
          request.resource == null
          || (
            request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    // Imágenes de catálogo de modelos (panel admin → OPCIONES → Modelos)
    match /catalogo_modelos/{fileName} {
      allow read: if tienePerfilActual();
      allow write: if puedeGestionarCatalogos()
        && (
          request.resource == null
          || (
            request.resource.size < 8 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    // Papeletas — fotos zonas / firma (auth + perfil)
    match /papeletas/{papeletaId}/{allPaths=**} {
      allow read: if tienePerfilActual();
      allow write: if tienePerfilActual()
        && (
          request.resource == null
          || (
            request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    // Reportes temporales (TTL 24h en app + CF)
    match /papeletas_reportes/{reporteId}/{allPaths=**} {
      allow read: if tienePerfilActual();
      allow write: if tienePerfilActual()
        && (
          request.resource == null
          || (
            request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    // Evidencias permanentes Ventas (promovidas)
    match /papeletas_ventas/{casoId}/{allPaths=**} {
      allow read: if tienePerfilActual();
      allow write: if tienePerfilActual()
        && (
          rolActual() == "VENTAS"
          || rolActual() == "SUPERVISOR"
          || rolActual() == "JEFE_PATIO"
          || rolActual() == "GERENTE_PLAZA"
          || rolActual() == "JEFE_REGIONAL"
          || rolActual() == "CORPORATIVO_USER"
          || rolActual() == "JEFE_OPERACION"
          || rolActual() == "PROGRAMADOR"
        )
        && (
          request.resource == null
          || (
            request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/.*')
          )
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
